
# 大模型API地址
OPENAI_BASE_URL=http://localhost:8080/v1

# 大模型名称
OPENAI_MODEL=Qwen3.5-9B

# 大模型API密钥
OPENAI_API_KEY=REPLACE_WITH_REAL_TOKEN

# 总 token 上限（输入 + 输出），用于上下文裁剪与安全保护，例如 4096、8192。
AGENT_MAX_CONTEXT_TOKENS=4096

# 模型单次回复最大 token 数，例如 1024。用于为输出预留空间，并透传给大模型。
AGENT_MAX_OUTPUT_TOKENS=1024

# 会话汇总窗口（天）。为空或非正整数则使用默认值 7。
CORVAL_SUMMARY_WINDOW_DAYS=

# LLM 并发窗口：控制同时进行的最大 LLM 请求数。非正整数/空则使用默认值。
LLM_CONCURRENCY_WINDOW=
