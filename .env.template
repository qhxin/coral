
# 大模型API地址
OPENAI_BASE_URL=http://localhost:8080/v1

# 大模型名称
OPENAI_MODEL=Qwen3.5-9B

# 大模型API密钥
OPENAI_API_KEY=REPLACE_WITH_REAL_TOKEN

# 总 token 上限（输入 + 输出），用于上下文裁剪与安全保护，例如 4096、8192。
AGENT_MAX_CONTEXT_TOKENS=4096

# 模型单次回复最大 token 数，例如 1024。用于为输出预留空间，并透传给大模型。
AGENT_MAX_OUTPUT_TOKENS=1024

# 输入侧估算余量（从「有效输入预算」中扣除），吸收 Qwen/llama.cpp 与 cl100k JSON 估算偏差。留空则自动取约 max(256, min(512, AGENT 有效输入/10))。经常上下文过长 / 被服务端拒。适当加大（例如 512、768、1024），让客户端更保守地少塞一点历史。
AGENT_CONTEXT_TOKEN_SLACK=

# 多模态（视觉）：每张图额外计入上下文的估算 token（保守值，用于历史摘要裁剪）。默认 1700。
AGENT_VISION_TOKENS_PER_IMAGE=1700

# 单张入站图片最大字节数（飞书/CLI）。默认约 10MiB。
AGENT_VISION_MAX_IMAGE_BYTES=10485760

# 用户仅发图无配文时，发给模型的默认中文提示（飞书/CLI）。
CORVAL_VISION_EMPTY_TEXT=

# 设为 1/true/on 时将会话中的入站图片写入 workspace/sessions/<id>/media/（不含请求里的 base64）。
CORVAL_SAVE_INBOUND_MEDIA=

# 会话汇总窗口（天）。为空或非正整数则使用默认值 7。
CORVAL_SUMMARY_WINDOW_DAYS=

# LLM 并发窗口：控制同时进行的最大 LLM 请求数。非正整数/空则使用默认值。
LLM_CONCURRENCY_WINDOW=

# 时区配置：支持 IANA 时区名（如 Asia/Shanghai）或偏移格式（如 UTC+8 / UTC+08:30）。
# 若不设置，则默认使用 UTC+8。
TIMEZONE=UTC+8

# 飞书自建应用 App ID（长连接模式 --feishu 必填）
FEISHU_APP_ID=

# 飞书自建应用 App Secret（长连接模式 --feishu 必填）
FEISHU_APP_SECRET=

# 群聊中仅在消息带有 @ 人员（mentions 非空）时回复；设为 0/false 则群聊每条文本都尝试回复。
FEISHU_GROUP_AT_ONLY=0

# 即时响应（减轻长连接回调阻塞）：留空或 false/0 为关闭；true/1 对用户消息添加大拇指表情（THUMBSUP）；其它非空字符串则先发该文本。
FEISHU_QUICK_ACK_TEXT=1
